# ── Base de données ────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ehu_secret
MYSQL_USER=ehu_user
MYSQL_PASSWORD=ehu_pass

# ── Django ─────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
# En production Railway, mettre : DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
# En production Railway, ajouter ton domaine : ALLOWED_HOSTS=localhost,127.0.0.1,xxx.railway.app

# ── CORS (origines autorisées) ─────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=
# En production, mettre l'URL Vercel : CORS_ALLOWED_ORIGINS=https://ehumotors.vercel.app

# ── KKiaPay ───────────────────────────────────────────────────────────────────
# Récupère tes clés sur https://app.kkiapay.me → Développeurs → Clés API
# Les 3 clés (publique, privée, secrète) sont TOUTES requises : le paiement est
# initié par le widget JS côté front (clé publique), et le backend vérifie
# ensuite la transaction via /api/v1/transactions/status (clé privée + secrète).
# Sans clé privée/secrète, la vérification échoue et aucune session n'est
# jamais marquée payée, même si le widget affiche un succès.
KKIAPAY_PUBLIC_KEY=
KKIAPAY_PRIVATE_KEY=
KKIAPAY_SECRET_KEY=
KKIAPAY_WEBHOOK_SECRET=
KKIAPAY_BASE_URL=https://api-sandbox.kkiapay.me
# En production : KKIAPAY_BASE_URL=https://api.kkiapay.me

